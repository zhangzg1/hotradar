# ==================== 应用配置 ====================
# 环境: development / production
ENVIRONMENT=development

# ==================== 数据库配置 ====================
# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ai_hotspot_monitor

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=604800

# ==================== 安全配置 ====================
# JWT 密钥（用于生成 Token）
# 生成方式: openssl rand -base64 32
JWT_SECRET_KEY=your_jwt_secret_key_here

# 设置加密密钥（用于加密敏感配置）
# 生成方式: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=your_encryption_key_here

# ==================== API Keys ====================
# 通义千问 ASR API（用于音频转文字）
# 获取方式: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key
QWEN_ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# YouTube Data API v3
# 获取方式: https://console.cloud.google.com/apis/credentials
# 需启用 YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# Twitter API（可选，需付费）
# 获取方式: https://twitterapi.io/
TWITTER_API_KEY=your_twitter_api_key

# ==================== SMTP 邮件配置 ====================
# SMTP 服务器地址
SMTP_HOST=smtp.example.com
# SMTP 端口（587 for TLS, 465 for SSL）
SMTP_PORT=465
# 是否使用 SSL
SMTP_SECURE=true
# SMTP 登录用户名
SMTP_USER=your_email@example.com
# SMTP 授权码或密码
SMTP_PASSWORD=your_smtp_password
# 发件人名称
SMTP_FROM_NAME=AI Hotspot Monitor

# ==================== Docker 部署专用配置 ====================
# 如果使用 Docker 部署，请使用以下配置：
# MYSQL_HOST=mysql
# REDIS_HOST=redis
